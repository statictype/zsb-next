{
  "name": "zsb-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format": "biome check --write ./src",
    "format:check": "biome check ./src",
    "images:unused": "tsx scripts/find-unused-images.ts",
    "images:unused:json": "tsx scripts/find-unused-images.ts --json",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "sanity": "sanity",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.4",
    "@portabletext/react": "^6.2.0",
    "@remixicon/react": "^4.9.0",
    "@sanity/client": "^7.22.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.28.0",
    "gsap": "^3.14.2",
    "next": "16.2.4",
    "next-sanity": "^13.0.7",
    "react": "^19",
    "react-dom": "^19",
    "sanity": "^5.28.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/blob": "^2.3.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "sharp": "^0.34.5",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.18.3+sha512.bbd16e6d7286fd7e01f6b3c0b3c932cda2965c06a908328f74663f10a9aea51f1129eea615134bf992831b009eabe167ecb7008b597f40ff9bc75946aadfb08d"
}
