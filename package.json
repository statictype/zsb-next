{
  "name": "zsb-next",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format": "biome check --write ./src",
    "format:check": "biome check ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "images:unused": "tsx scripts/find-unused-images.ts",
    "images:unused:json": "tsx scripts/find-unused-images.ts --json",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "typegen:watch": "sanity typegen generate --watch",
    "sanity": "sanity",
    "prepare": "git config core.hooksPath .githooks && panda codegen"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@next/third-parties": "^16.2.4",
    "@portabletext/react": "^6.2.0",
    "@remixicon/react": "^4.9.0",
    "@sanity/client": "^7.22.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/ui": "^3.2.0",
    "@sanity/vision": "^5.28.0",
    "next": "16.2.4",
    "next-sanity": "^13.0.7",
    "react": "^19",
    "react-dom": "^19",
    "sanity": "^5.28.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@pandacss/dev": "^1.11.3",
    "@pandacss/studio": "^1.11.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
