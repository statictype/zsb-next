{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@e2e/*": ["./e2e/*"],
      "@calendar/*": ["./src/app/(site)/editions/[year]/_components/Calendar/*"],
      "@edition/*": ["./src/app/(site)/editions/[year]/*"],
      "@edition-components/*": ["./src/app/(site)/editions/[year]/_components/*"],
      "@root/*": ["./*"],
      "@scripts/*": ["./scripts/*"],
      "@site/*": ["./src/app/(site)/*"],
      "@site-components/*": ["./src/app/(site)/_components/*"],
      "@studio/*": ["./src/app/studio/[[...tool]]/*"],
      "@test/*": ["./test/*"],
      "styled-system": ["./styled-system"],
      "styled-system/*": ["./styled-system/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
