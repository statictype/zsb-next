# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/blob-report
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# personal notes / blog drafts
/journal/

# claude code — local-only settings (skills/ is shared)
/.claude/settings.local.json
# Sanity dataset backup dumps
zsb-backup-*.tar.gz

# panda css generated output
/styled-system

# design-audit styleguide route — throwaway, regenerated by /design-audit
/src/app/styleguide
